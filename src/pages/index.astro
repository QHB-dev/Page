---
import Base from '../layouts/Base.astro';
---
<Base title="Shedio — A quiet fitness platform" active="features" isHome={true} overlayNav={true}
      description="Low-impact training — Pilates, Taichi, walking. Built around your body, your level, your day.">

  <!-- Hero（图4：整幅照片 + 文字压左下；Nav 由 Base 以 overlay 方式压在上面） -->
  <section class="home-hero">
    <div class="home-hero-bg ph">
      <picture>
        <source media="(max-width:600px)" srcset="/images/hero-1-mobile.webp">
        <img class="hero-slide is-front" id="heroImgA" src="/images/hero-1.webp" alt=""
             loading="eager" fetchpriority="high" decoding="sync"
             onerror="var s=this.parentElement.querySelector('source');if(s)s.remove();this.onerror=null;this.src='/images/hero-1.webp'">
      </picture>
      <img class="hero-slide" id="heroImgB" alt="">
    </div>
    <div class="home-hero-inner">
      <h1 class="home-hero-title" id="heroTitle">Home Pilates Program:<br>low-impact training<br>beginner-friendly</h1>
      <!-- 暂时隐藏 Get Started（恢复：把 display:none 去掉即可） -->
      <a class="btn btn-light" id="heroCta" style="cursor:pointer;display:none">Get Started&nbsp; →</a>
    </div>
    <div class="home-hero-dots" id="heroDots">
      <button data-i="0" class="active">1</button>
      <button data-i="1">2</button>
      <button data-i="2">3</button>
    </div>
  </section>

  <!-- App Features（交替错落 · 图片占位） -->
  <div class="wrap" id="features">
    <div class="af-head">
      <h2 class="af-head-title">Every detail, within reach</h2>
      <div class="af-underline"></div>
    </div>

    <!-- 块 A：Pilates（文字左 / 图右） -->
    <div class="af-block">
      <div class="af-text">
        <span class="af-num">01</span>
        <h3 class="af-sub-h">Pilates, Taichi,<br>and walking plans</h3>
        <p class="af-desc">Choose a plan that fits your pace, with clear day-by-day guidance and a gentle four-stage journey.</p>
        <div class="af-points">
          <div class="af-point"><span class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M22 10v6"/><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/></svg></span><div><h4>Beginner-friendly</h4><p>Clear guidance, every step</p></div></div>
          <div class="af-point"><span class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg></span><div><h4>Low impact, high results</h4><p>Effective, gentle, sustainable</p></div></div>
          <div class="af-point"><span class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 7h6v6"/><path d="m22 7-8.5 8.5-5-5L2 17"/></svg></span><div><h4>Track progress</h4><p>See how far you've come</p></div></div>
        </div>
      </div>
      <div class="af-visual">
        <div class="af-shot portrait" data-ph="手机截图占位 · app-plan.webp">
          <img src="/images/app-plan.webp" alt="My plan screen" loading="lazy" decoding="async" onload="this.parentNode.classList.add('loaded')" onerror="this.style.display='none'">
        </div>
      </div>
    </div>

    <!-- 块 B：Micro（图左 / 文字右） -->
    <div class="af-block rev">
      <div class="af-text">
        <span class="af-num">02</span>
        <h3 class="af-sub-h">Micro Achievement</h3>
        <p class="af-desc">Small moves still move you forward, even on low-energy days.</p>
        <div class="af-points">
          <div class="af-point"><span class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg></span><div><h4>Every rep counts</h4><p>Even a one-minute stretch</p></div></div>
          <div class="af-point"><span class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg></span><div><h4>Two moods</h4><p>Finish a move, change the mood</p></div></div>
        </div>
      </div>
      <div class="af-visual">
        <div class="af-shot wide" data-ph="双机截图占位 · app-micro.webp">
          <img src="/images/app-micro.webp" alt="Micro achievement screens" loading="lazy" decoding="async" onload="this.parentNode.classList.add('loaded')" onerror="this.style.display='none'">
        </div>
      </div>
    </div>

    <!-- 块 C：Made to fit（文字左 / 图右） -->
    <div class="af-block">
      <div class="af-text">
        <span class="af-num">03</span>
        <h3 class="af-sub-h">Made to fit you</h3>
        <p class="af-desc">Built around your body, your level, your day.</p>
        <div class="af-points">
          <div class="af-point"><span class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></span><div><h4>Matches your goal</h4><p>Every session, on purpose</p></div></div>
          <div class="af-point"><span class="pico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg></span><div><h4>Joint-safe by design</h4><p>No jumping, no strain</p></div></div>
        </div>
      </div>
      <div class="af-visual">
        <div class="af-shot portrait" data-ph="手机截图占位 · app-detail.webp">
          <img src="/images/app-detail.webp" alt="Workout detail screen" loading="lazy" decoding="async" onload="this.parentNode.classList.add('loaded')" onerror="this.style.display='none'">
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // img = 桌面图；mobileImg = 手机端独立 3:4 竖图。
    // 手机图未上传或加载失败时，会自动回退到桌面图。
    var slides = [
      { funnel:"wall-pilates", img:"/images/hero-1.webp", mobileImg:"/images/hero-1-mobile.webp", pos:"50% center", mobileScale:1.55, mobileOrigin:"100% 70%", title:"Home Pilates Program:<br>low-impact training<br>beginner-friendly" },
      { funnel:"taichi-walk",  img:"/images/hero-2.webp", mobileImg:"/images/hero-2-mobile.webp", pos:"72% center", mobilePosition:"center", title:"Taichi Walk Program:<br>slow, low-impact,<br>and deeply calming" },
      { funnel:"crossfit", img:"/images/hero-3.webp", mobileImg:"/images/hero-3-mobile.webp", pos:"70% center", title:"CrossFit Program:<br>functional strength,<br>for all levels" }
    ];
    var mqMobile = window.matchMedia('(max-width:600px)');
    function imageFor(s){ return mqMobile.matches && s.mobileImg ? s.mobileImg : s.img; }
    function posFor(s){ return mqMobile.matches ? 'center' : (s.pos || 'center'); }
    function applyFraming(el,s){
      if(!el) return;
      el.style.objectFit=mqMobile.matches && s.mobileFit ? s.mobileFit : 'cover';
      el.style.objectPosition=mqMobile.matches && s.mobilePosition ? s.mobilePosition : posFor(s);
      el.style.setProperty('--hero-scale',mqMobile.matches && s.mobileScale ? s.mobileScale : 1);
      el.style.transformOrigin=mqMobile.matches && s.mobileOrigin ? s.mobileOrigin : 'center';
    }
    var dots=document.querySelectorAll('#heroDots button');
    var title=document.getElementById('heroTitle');
    var cta=document.getElementById('heroCta');
    // 两层图片水平翻页
    var layers=[document.getElementById('heroImgA'), document.getElementById('heroImgB')];
    var front=0, cur=0, transitioning=false, queued=null;
    // 首图由 HTML 以最高优先级加载；其余轮播图等首图完成后再预加载，避免抢带宽。
    function preloadRemaining(){
      slides.slice(1).forEach(function(s){ var im=new Image(); im.decoding='async'; im.src=imageFor(s); });
    }
    if(layers[0] && !layers[0].complete) layers[0].addEventListener('load',preloadRemaining,{once:true});
    else if('requestIdleCallback' in window) requestIdleCallback(preloadRemaining,{timeout:1500});
    else setTimeout(preloadRemaining,300);
    applyFraming(layers[0],slides[0]);
    function render(i,direction){
      if(i===cur && !transitioning) return;
      if(transitioning){ queued={i:i,direction:direction}; return; }
      transitioning=true;
      direction=direction || (i>cur ? 1 : -1); // 1=前进（右→左），-1=后退（左→右）
      cur=i;
      title.innerHTML=slides[i].title;
      dots.forEach(function(d,di){ d.classList.toggle('active',di===i); });
      if(!layers[0]||!layers[1]){ transitioning=false; return; }
      // 新图先在屏幕左侧就位，构图缩放比例在动画前一次设定；
      // 切换时只做水平位移，不展示任何缩放过程。
      var s=slides[i], back=layers[1-front], pre=new Image();
      function swap(ok){
        if(ok){
          var old=layers[front];
          var resolved=s._resolvedImg || imageFor(s);
          // heroImgA 位于 <picture> 内；轮播复用该层时必须同步更新 source，
          // 否则手机端 source 会一直覆盖 img.src，造成标题已切换但图片仍是第一张。
          var source=back.parentElement && back.parentElement.tagName==='PICTURE'
            ? back.parentElement.querySelector('source') : null;
          if(source) source.srcset=resolved;
          back.style.transition='none';
          var enterX=direction===1 ? '100%' : '-100%';
          var leaveX=direction===1 ? '-100%' : '100%';
          back.style.setProperty('--hero-x',enterX);
          applyFraming(back,s);
          back.src=resolved;
          back.classList.add('is-front');
          void back.offsetWidth;
          back.style.transition='transform 1.5s cubic-bezier(.22,.61,.36,1)';
          old.style.transition='transform 1.5s cubic-bezier(.22,.61,.36,1)';
          back.style.setProperty('--hero-x','0%');
          old.style.setProperty('--hero-x',leaveX);
          front=1-front;
          var finished=false;
          function finish(){
            if(finished) return; finished=true;
            back.removeEventListener('transitionend',done);
            old.classList.remove('is-front');
            old.style.transition='none';
            old.style.setProperty('--hero-x',direction===1 ? '100%' : '-100%');
            transitioning=false;
            if(queued){ var q=queued; queued=null; render(q.i,q.direction); }
          }
          function done(e){ if(e.propertyName==='transform') finish(); }
          back.addEventListener('transitionend',done);
          setTimeout(finish,1700);
        }
        else { back.removeAttribute('src'); back.classList.remove('is-front'); transitioning=false; } // 图缺失→保留当前层
      }
      pre.onerror=function(){
        // 手机竖图尚未上传时，使用已有桌面图兜底。
        if(pre.src.indexOf(s.img)===-1){ pre.src=s.img; }
        else { swap(false); }
      };
      pre.onload=function(){
        s._resolvedImg=pre.src;
        swap(true);
      };
      pre.src=imageFor(s);
    }
    if(slides.length<=1){ document.getElementById('heroDots').style.display='none'; }
    // 自动切换（手动操作后重新计时，避免刚滑完又立刻跳）
    var heroTimer;
    function restart(){ clearInterval(heroTimer); heroTimer=setInterval(function(){ render((cur+1)%slides.length,1); }, 6000); }
    function go(i){
      var target=(i%slides.length+slides.length)%slides.length;
      if(target===cur && !transitioning) return;
      render(target,target>cur ? 1 : -1);
      restart();
    }
    // 圆点点击
    dots.forEach(function(d){ d.addEventListener('click',function(){ go(+d.dataset.i); }); });
    // 手机滑动切换：左滑下一张、右滑上一张
    var heroEl=document.querySelector('.home-hero');
    if(heroEl){
      var sx=0, sy=0, tracking=false;
      heroEl.addEventListener('touchstart',function(e){ var t=e.changedTouches[0]; sx=t.clientX; sy=t.clientY; tracking=true; },{passive:true});
      heroEl.addEventListener('touchend',function(e){
        if(!tracking) return; tracking=false;
        var t=e.changedTouches[0], dx=t.clientX-sx, dy=t.clientY-sy;
        if(Math.abs(dx)>40 && Math.abs(dx)>Math.abs(dy)){
          var direction=dx<0 ? 1 : -1;
          var target=(cur+direction+slides.length)%slides.length;
          render(target,direction); restart();
        }
      },{passive:true});
    }

    // 视口跨越手机断点 / 旋转 → 切换当前图片版本。
    function switchResponsiveImage(){
      var s=slides[cur], active=layers[front], pre=new Image();
      s._resolvedImg='';
      pre.onload=function(){
        var source=active.parentElement && active.parentElement.tagName==='PICTURE'
          ? active.parentElement.querySelector('source') : null;
        if(source) source.srcset=pre.src;
        active.style.transition='none'; applyFraming(active,s); active.src=pre.src;
      };
      pre.onerror=function(){ if(pre.src.indexOf(s.img)===-1) pre.src=s.img; };
      pre.src=imageFor(s);
    }
    if(mqMobile.addEventListener) mqMobile.addEventListener('change', switchResponsiveImage);

    restart();
  </script>

  <style is:global>
    .home-hero{position:relative;min-height:100vh;min-height:100svh;overflow:hidden;border-radius:0;background:linear-gradient(135deg,var(--warm),var(--warm-2))}
    .home-hero-bg,.home-hero-bg.ph,.home-hero-bg picture,.home-hero-bg .hero-slide{border-radius:0}
    .home-hero-bg{position:absolute;inset:0;background-image:url("data:image/webp;base64,UklGRqIAAABXRUJQVlA4IJYAAAAwBQCdASogABIAPwFoqk6rJaOiMAgBYCAJYwCuHBgbrdzTP9T1GnEJpYxC0gnYPS1jAAD73L+Q/fPwMLyVhLX0M5DzK7KWKwFrKa9ECm/uJ/Xg4R28Sl2pXYOxP5JfGvOiwc2hvQn4lDXDHICbSpmdpk9g+Q59Kn5YQzdsGYyVjRoB7KaPTZ70o+DlDb6QKZSWkU6nQAA=");background-size:cover;background-position:center}
    /* 整幅图片从左向右翻页；缩放比例不参与过渡。 */
    .home-hero-bg .hero-slide{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transform:translateX(var(--hero-x,0%)) scale(var(--hero-scale,1));z-index:1;will-change:transform}
    .home-hero-bg .hero-slide.is-front{opacity:1}
    .home-hero::after{content:"";position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(to bottom,rgba(0,0,0,.28),transparent 22%,transparent 55%,rgba(0,0,0,.42))}
    .home-hero-inner{position:absolute;left:clamp(24px,4vw,80px);bottom:9%;z-index:2;width:min(820px,calc(100vw - 160px));padding:0}
    .home-hero-title{color:#fff;font-size:var(--fs-hero);line-height:var(--lh-display);font-weight:var(--fw-bold);letter-spacing:var(--ls-display);margin-bottom:26px;text-shadow:0 2px 22px rgba(0,0,0,.35);white-space:nowrap}
    .home-hero-dots{position:absolute;right:clamp(24px,4vw,80px);bottom:9%;z-index:2;display:flex;gap:8px}
    .home-hero-dots button{width:34px;height:34px;border-radius:50%;border:0;font-size:13px;font-weight:600;cursor:pointer;background:rgba(255,255,255,.9);color:var(--ink)}
    .home-hero-dots button.active{background:var(--coral);color:#fff}

    /* 章节头：大标题 + 珊瑚小下划线 */
    .af-head{padding:var(--section-y) 0 var(--space-2)}
    .af-head-title{font-size:var(--fs-display);font-weight:var(--fw-bold);letter-spacing:var(--ls-display);line-height:var(--lh-display);text-wrap:balance}
    .af-underline{width:52px;height:3px;background:var(--coral);border-radius:2px;margin-top:var(--space-4)}

    .af-block{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-8);align-items:center;padding:var(--section-y) 0}
    .af-block.rev .af-visual{order:-1}
    /* 宽版（两机）那块：给图片列更多宽度，让 app-micro 更大 */
    .af-block.rev{grid-template-columns:1.25fr 0.75fr}

    /* 编辑式序号：01 —— （替代原来的小下划线，给每块秩序感） */
    .af-num{display:inline-flex;align-items:center;gap:10px;font-size:var(--fs-small);font-weight:var(--fw-bold);letter-spacing:.14em;color:var(--coral);margin-bottom:var(--space-4)}
    .af-num::after{content:"";width:26px;height:1.5px;background:currentColor;opacity:.55;border-radius:2px}

    .af-sub-h{font-size:var(--fs-h3);font-weight:var(--fw-bold);line-height:var(--lh-heading);letter-spacing:var(--ls-heading);margin-bottom:var(--space-3)}
    .af-desc{color:var(--muted);font-size:var(--fs-body);max-width:42ch;margin-bottom:var(--space-6);line-height:var(--lh-body)}
    .af-points{display:flex;flex-direction:column;gap:var(--space-4)}
    .af-point{display:flex;gap:var(--space-3);align-items:center}
    /* 要点图标：柔绿圆底 + 森绿图标（鼠尾草绿，与珊瑚序号形成「陶土×草木」高级配色） */
    .af-point .pico{width:40px;height:40px;border-radius:50%;background:var(--ok-soft);display:grid;place-items:center;color:var(--ok);flex-shrink:0}
    .af-point .pico svg{width:19px;height:19px;display:block}
    .af-point h4{font-size:var(--fs-h5);font-weight:var(--fw-semibold);margin-bottom:1px}
    .af-point p{font-size:var(--fs-small);color:var(--muted)}

    /* 截图直接平铺（无舞台底、无阴影） */
    .af-visual{display:grid;place-items:center}
    .af-shot{position:relative;width:100%;border-radius:var(--r-lg);overflow:hidden;background:linear-gradient(135deg,var(--warm),var(--warm-2));display:grid;place-items:center}
    .af-shot::after{content:attr(data-ph);color:rgba(60,50,40,.42);font-size:13px;letter-spacing:.5px;padding:10px;text-align:center}
    .af-shot img{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;z-index:1}
    .af-shot.loaded{background:none}
    .af-shot.loaded::after{display:none}
    .af-shot.portrait{max-width:360px;aspect-ratio:22/34;margin:0 auto}
    .af-shot.wide{max-width:720px;aspect-ratio:20/21;margin:0 auto}

    @media(max-width:900px){
      .home-hero-inner{left:0;width:100%;padding:0 22px;bottom:11%}
      .home-hero-title{font-size:clamp(30px,7.5vw,44.8px);line-height:1.1;white-space:normal}
      .af-block,.af-block.rev{grid-template-columns:1fr;gap:var(--space-7);padding:40px 0}
      .af-block.rev .af-visual{order:0}
    }
    /* 手机端：首屏拆为上方图片 + 下方独立文案区。 */
    @media(max-width:600px){
      .home-hero{height:100svh;min-height:620px;background:#fff}
      .home-hero-bg{inset:0 0 auto;height:66svh;min-height:410px;background-image:url("data:image/webp;base64,UklGRqYAAABXRUJQVlA4IJoAAACwBQCdASoYACAAPwFkrk8rJSQiMBgMAWAgCWUAnQBX8LLPD76aqjrwkqCZLuaTfWE25XbeAAAA/tSeqv3/6VxxnWeVcoHsLIt9xi8mmBkP2CmBluuxKYcW/1/ZLZ69x8RUg8w9OHuklIXDh/25jFpWnkDKxu1v/gYC19CQdiGOa/ZSmR2ie9nbxEWJNnqyBASM7uPvItQLgAAA");background-size:cover;background-position:center}
      .home-hero::after{bottom:auto;height:66svh;background:linear-gradient(to bottom,rgba(0,0,0,.3),transparent 28%,transparent 72%,rgba(0,0,0,.12))}
      .home-hero-inner{left:0;top:66svh;bottom:0;width:100%;height:34svh;min-height:210px;padding:clamp(22px,3.4vh,32px) 24px 18px;background:#fff}
      .home-hero-title{color:var(--ink);font-size:clamp(28px,8.2vw,38px);line-height:1.08;margin:0;text-shadow:none;white-space:normal}
      .home-hero-dots{left:50%;right:auto;top:calc(66svh - 34px);bottom:auto;transform:translateX(-50%);gap:9px}
      .home-hero-dots button{width:9px;height:9px;padding:0;font-size:0;background:rgba(255,255,255,.78)}
      .home-hero-dots button.active{width:13px;height:13px;margin:-2px;border:2px solid #fff;background:transparent}
      .af-head{padding:44px 0 4px}
      .af-head-title{font-size:clamp(26px,8.4vw,34px)}
      .af-block{gap:var(--space-6);padding:30px 0}
      .af-shot.portrait{max-width:280px}
      .af-shot.wide{max-width:100%}
    }
  </style>
</Base>
