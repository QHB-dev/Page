---
import Base from '../../layouts/Base.astro';
---
<Base title="The Shedio Journal — Blog" active="blog" showBlog={true} brand="shedio"
      description="Notes on moving, eating, and feeling good — gently, at your own pace, on your own terms.">

  <main class="wrap">
    <section class="masthead">
      <span class="eyebrow">The Shedio Journal</span>
      <h1>Shed the pressure. Start anytime.</h1>
      <p>Notes on moving, eating, and feeling good — gently, at your own pace, on your own terms.</p>
    </section>

    <section class="feature">
      <a class="feature-main card" href="/blog/article/?id=10">
        <div class="fimg ph" data-ph="starting-after-time-away.webp"><img src="/images/starting-after-time-away.webp" alt="" onload="this.parentNode.classList.add('has-img')" onerror="this.style.display='none'"></div>
        <span class="tag">Beginnings</span>
        <h2>Starting after time away</h2>
        <p>If you've begun before and drifted away, you're not starting from zero — you're starting from experience.</p>
        <div class="meta">Shedio Team · 6-min read</div>
      </a>
      <div class="feature-side">
        <a class="side-item card" href="/blog/article/?id=11">
          <div class="simg ph" data-ph="a-gentler-way.webp"><img src="/images/a-gentler-way.webp" alt="" onload="this.parentNode.classList.add('has-img')" onerror="this.style.display='none'"></div>
          <div><span class="chip">Beginnings</span><h3>The all-or-nothing trap (and a gentler way)</h3><div class="meta">6-min read</div></div>
        </a>
        <a class="side-item card" href="/blog/article/?id=12">
          <div class="simg ph" data-ph="feeling-more-tired.webp"><img src="/images/feeling-more-tired.webp" alt="" onload="this.parentNode.classList.add('has-img')" onerror="this.style.display='none'"></div>
          <div><span class="chip">Wellbeing</span><h3>Running on Empty? Here's What Might Be Going On</h3><div class="meta">5-min read</div></div>
        </a>
        <!-- 暂时隐藏 New to Shedio? / Find your starting point（去掉 display:none 即恢复） -->
        <div class="start-card" style="display:none">
          <span class="eyebrow">New to Shedio?</span>
          <a href="#" class="link-accent" id="startLink">Find your starting point →</a>
        </div>
      </div>
    </section>

    <div class="brand-band">
      <div class="brand-band-media ph" data-ph="blog-band.webp"><img src="/images/blog-band.webp" alt="" onload="this.parentNode.classList.add('has-img')" onerror="this.style.display='none'"></div>
      <span class="eyebrow">On your terms</span>
      <h2>It was never about willpower.</h2>
      <a href="/about/" class="link-muted" style="display:none">Discover Shedio →</a>
    </div>

    <div class="latest-head">
      <h2>Latest</h2>
      <span class="cats">Beginnings · Movement · Food · Wellbeing</span>
    </div>
    <div class="grid" id="postGrid"></div>
    <div class="showmore" id="showMoreWrap" style="display:none">
      <button class="btn btn-outline" id="showMoreBtn">Show more</button>
    </div>
  </main>

  <script is:inline>
    function esc(s){return String(s==null?'':s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];});}
    // 封面占位框：有 coverImage 就渲染 <img>（放入图片自动盖住占位，图缺失则回退占位）
    function phBox(cls, cover){
      if(!cover) return '<div class="'+cls+' ph"></div>';
      var name = cover.split('/').pop();
      return '<div class="'+cls+' ph" data-ph="'+esc(name)+'">'+
        '<img src="'+esc(cover)+'" alt="" loading="lazy" '+
        'onload="this.parentNode.classList.add(\'has-img\')" onerror="this.style.display=\'none\'"></div>';
    }
    document.getElementById('startLink').href = Shedio.guideUrl('app');
    var grid = document.getElementById('postGrid');
    var PAGE = 6, shown = 0, all = [];
    function skeleton(n){
      var s=''; for(var i=0;i<n;i++){ s+='<div class="sk-card"><div class="skeleton sk-img"></div>'+
        '<div class="skeleton sk-line w40"></div><div class="skeleton sk-line w90"></div>'+
        '<div class="skeleton sk-line w60"></div></div>'; }
      grid.innerHTML = s;
    }
    function cardHtml(p){
      return '<a class="card" href="/blog/article/?id='+encodeURIComponent(p.id)+'">'+
        '<button class="share-btn" onclick="sharePost(event,'+JSON.stringify(p.id)+')" aria-label="Share">↗</button>'+
        phBox('card-img', p.coverImage)+
        '<span class="chip">'+esc(p.category)+'</span>'+
        '<h3>'+esc(p.title)+'</h3>'+
        '<p>'+esc(p.excerpt)+'</p>'+
        '<div class="card-meta">Shedio Team · '+esc(p.date||'')+' · '+esc(p.readTime||'')+'</div></a>';
    }
    function renderMore(){
      var next = all.slice(shown, shown+PAGE);
      grid.insertAdjacentHTML('beforeend', next.map(cardHtml).join(''));
      shown += next.length;
      document.getElementById('showMoreWrap').style.display = shown < all.length ? 'block' : 'none';
    }
    window.sharePost = function(e,id){
      e.preventDefault(); e.stopPropagation();
      var url = location.origin + '/blog/article/?id=' + id;
      if(navigator.share){ navigator.share({ url: url }).catch(function(){}); }
      else if(navigator.clipboard){ navigator.clipboard.writeText(url); }
    };
    skeleton(6);
    Shedio.Blog.list().then(function(posts){
      all = posts.filter(function(p){ return [10,11,12].indexOf(+p.id)===-1; });
      if(!all.length){ grid.innerHTML = '<div class="state-msg">New pieces are on the way. Check back soon.</div>'; return; }
      grid.innerHTML=''; shown=0; renderMore();
    }).catch(function(){
      grid.innerHTML = '<div class="state-msg">We couldn’t load these just now.'+
        '<br><button class="btn btn-outline" onclick="location.reload()">Tap to try again</button></div>';
    });
    document.getElementById('showMoreBtn').addEventListener('click', renderMore);
  </script>

  <style is:global>
    .masthead{padding:52px 0 36px;border-bottom:1px solid var(--line-strong)}
    .masthead h1{font-size:var(--fs-h1);font-weight:var(--fw-semibold);letter-spacing:var(--ls-display);line-height:var(--lh-heading);margin:14px 0 10px}
    .masthead p{color:var(--muted);font-size:var(--fs-lead);line-height:var(--lh-snug);max-width:var(--measure-lead)}
    .feature{display:grid;grid-template-columns:1.4fr 1fr;gap:var(--space-6);padding:var(--flow-tight) 0;align-items:start}
    .feature-main .fimg{aspect-ratio:16/9;border-radius:var(--r-md);margin-bottom:var(--space-4);transition:box-shadow var(--dur) var(--ease)}
    .feature-main:hover .fimg{box-shadow:var(--elev-1)}
    .feature-main .tag{color:var(--muted)}
    .feature-main h2{font-size:var(--fs-h3);font-weight:var(--fw-semibold);line-height:var(--lh-snug);margin:var(--space-2) 0}
    .feature-main p{color:var(--muted);max-width:52ch}
    .feature-main .meta{font-size:var(--fs-caption);color:var(--muted);margin-top:var(--space-2)}
    .feature-side{display:flex;flex-direction:column;gap:var(--space-5)}
    .side-item{display:grid;grid-template-columns:96px 1fr;gap:var(--space-3);align-items:center}
    .side-item .simg{aspect-ratio:1/1;border-radius:var(--r-sm)}
    .side-item .chip{display:inline-block;font-size:var(--fs-caption);color:var(--muted);background:var(--surface-2);padding:2px 8px;border-radius:var(--r-pill);margin-bottom:var(--space-1)}
    .side-item h3{font-size:var(--fs-h5);font-weight:var(--fw-semibold);line-height:var(--lh-snug);margin:var(--space-1) 0}
    .side-item .meta{font-size:var(--fs-caption);color:var(--muted)}
    .chip{display:inline-block;font-size:var(--fs-caption);color:var(--muted);background:var(--surface-2);padding:3px 10px;border-radius:var(--r-pill)}
    .brand-band{position:relative;overflow:hidden;background:var(--surface-2);border-radius:var(--r-md);text-align:center;padding:var(--space-7) var(--space-5);margin:var(--space-4) 0 var(--space-3)}
    /* 背景图层：放入 blog-band.webp 自动铺满 */
    .brand-band-media{position:absolute;inset:0;border-radius:inherit;z-index:0}
    /* 柔和米色蒙版：保证图上文字仍可读（调淡，让图更清楚露出） */
    .brand-band::before{content:"";position:absolute;inset:0;background:rgba(243,239,230,.3);z-index:1;pointer-events:none}
    .brand-band > .eyebrow,.brand-band > h2,.brand-band > a{position:relative;z-index:2}
    .brand-band .eyebrow{margin-bottom:10px}
    .brand-band h2{font-size:var(--fs-h3);font-weight:var(--fw-semibold);line-height:var(--lh-heading)}
    .brand-band a{display:inline-block;margin-top:14px}
    .latest-head{display:flex;justify-content:space-between;align-items:baseline;padding:34px 0 20px;border-top:1px solid var(--line-strong);margin-top:18px}
    .latest-head h2{font-size:var(--fs-h3);font-weight:var(--fw-semibold)}
    .latest-head .cats{font-size:var(--fs-small);color:var(--muted)}
    .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-6) var(--space-5)}
    .grid .chip{margin-bottom:6px}
    .card-meta{font-size:var(--fs-caption);color:var(--muted);margin-top:8px}
    .showmore{text-align:center;padding:36px 0 10px}
    @media(max-width:860px){.feature{grid-template-columns:1fr}.grid{grid-template-columns:1fr}}
    @media(max-width:1100px) and (min-width:861px){.grid{grid-template-columns:1fr 1fr}}
    /* 手机端细化（≤600px） */
    @media(max-width:600px){
      .masthead{padding:40px 0 26px}
      .masthead p{font-size:16px}
      .feature{padding:26px 0;gap:22px}
      .feature-main .fimg{margin-bottom:14px;aspect-ratio:4/3}
      .brand-band{padding:34px 18px;margin:6px 0}
      .latest-head{flex-direction:column;gap:4px;align-items:flex-start}
      .grid{gap:26px}
    }
  </style>
</Base>
