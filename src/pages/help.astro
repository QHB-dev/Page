---
import Base from '../layouts/Base.astro';
---
<Base title="Help Center — Shedio" active="">
  <main class="wrap" style="min-height:52vh;display:flex;flex-direction:column;justify-content:center;padding:80px 0">
    <span class="eyebrow" style="margin-bottom:12px">Help Center</span>
    <h1 style="font-size:var(--fs-h1);font-weight:var(--fw-bold);line-height:var(--lh-heading);letter-spacing:var(--ls-display);color:var(--navy);max-width:16ch">We're here when you need us.</h1>
    <p class="muted" style="font-size:var(--fs-lead);line-height:var(--lh-snug);max-width:var(--measure-lead);margin-top:16px">
      This page is coming together. In the meantime, reach us any time at
      <a href="mailto:support@shedio.life" style="color:var(--ink);font-weight:600">support@shedio.life</a>.
    </p>
  </main>
</Base>
