---
import '../styles/global.css';
import '../styles/cookiebot.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MenuOverlay from '../components/MenuOverlay.astro';

interface Props {
  title: string;
  description?: string;
  active?: 'features' | 'about' | 'blog' | '';
  isHome?: boolean;
  showBlog?: boolean;
  brand?: string;
  bare?: boolean;       // login/admin 等极简页：不渲染全局 Nav/Footer/Menu
  overlayNav?: boolean; // 首页：Nav 透明压在 Hero 照片上
  preloadImage?: string; // 非首页页面的首屏主图
}
const {
  title,
  description = 'Shedio — low-impact training. Built around your body, your level, your day.',
  active = '', isHome = false, showBlog = false, brand = 'Shedio', bare = false, overlayNav = false,
  preloadImage = '',
} = Astro.props;

const COOKIEBOT_ID = '5b835602-6473-465e-8f36-de64d4a371d6';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico?v=2" sizes="64x64" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" sizes="any" />

  {isHome && (
    <>
      <!-- 首屏图优先下载；浏览器只会选择匹配当前屏幕的一张。 -->
      <link rel="preload" as="image" href="/images/hero-1-mobile.webp" media="(max-width: 600px)" fetchpriority="high" />
      <link rel="preload" as="image" href="/images/hero-1.webp" media="(min-width: 601px)" fetchpriority="high" />
    </>
  )}
  {!isHome && preloadImage && (
    <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
  )}

  <link rel="preconnect" href="https://consent.cookiebot.com" />
  <link rel="preconnect" href="https://consentcdn.cookiebot.com" />

  <!-- Cookiebot 在生产环境全站生效；本地开发不请求真实 CMP，避免未登记域名干扰调试。 -->
  {import.meta.env.PROD && (
    <>
      <script is:inline src="/assets/cookiebot.js"></script>
      <script id="Cookiebot" is:inline
              src="https://consent.cookiebot.com/uc.js"
              data-cbid={COOKIEBOT_ID}
              data-blockingmode="auto"
              type="text/javascript"></script>
    </>
  )}

  <!-- 字体：preconnect 提前建连 + 非阻塞加载 Inter（font-display:swap，先用系统字体兜底，避免 FOIT）。 -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Onest:wght@500;700&display=swap"
  />

  <!-- 预留接口层 + 全局交互（放在 public/assets，对接后端只改这两个文件）。
       api.js 仅定义 window.Shedio；app.js 内部等 DOMContentLoaded，放 head 安全，
       且保证在各页面末尾的内联脚本之前就绪。 -->
  <script is:inline src="/assets/api.js"></script>
  <script is:inline src="/assets/app.js"></script>
</head>
<body>
  {!bare && <Nav active={active} isHome={isHome} showBlog={showBlog} brand={brand} overlay={overlayNav} />}

  <slot />

  {!bare && <Footer brand={brand} />}
  {!bare && <MenuOverlay />}
</body>
</html>
