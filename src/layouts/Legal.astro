---
// 法务/政策页统一版式：
//  · 顶部 hero（居中大标题）
//  · 右上角语言下拉（预留多语言接口，接 window.Shedio.i18n —— 见 /assets/api.js、app.js）
//  · 左侧“所有 policy”跳转导航（当前页高亮；已有的可点，暂缺的为占位）
//  · 右侧正文（渲染各 policy 的 Markdown）
// 每个 policy 的 .md 通过 frontmatter 指定 layout 与 title / heading / updated。
import Base from './Base.astro';
import CookieDeclaration from '../components/CookieDeclaration.astro';

const { frontmatter = {} } = Astro.props;
const {
  title = 'Legal — Shedio',
  heading = 'Legal',
  updated,
  description = 'Shedio legal & policy information.',
  cookieDeclaration = false,
} = frontmatter;

// 当前路径（去掉结尾斜杠，配合 trailingSlash:ignore）
const path = (Astro.url.pathname.replace(/\/+$/, '') || '/');

// === 单一数据源：站点全部 policy 入口 ===
// href 为 null = 占位（暂无文档/为同意工具，先不落地）。要新增 policy：加一项并给 href。
const policies = [
  { label: 'Privacy Policy',                         href: '/privacy' },
  { label: 'Cookie Policy',                          href: '/cookie-policy' },
  { label: 'Terms and conditions of use',           href: '/terms' },
  { label: 'Subscription terms',                     href: '/subscription-terms' },
  { label: 'Money-back policy',                      href: '/money-back-policy' },
  { label: 'Consumer Health Data Privacy Policy',    href: '/consumer-health-data' },
];

// 先只做 EN；多语言列表保留在 /assets/api.js 的 CONFIG.I18N.LANGUAGES，将来要恢复下拉时再用。
---
<Base title={title} active="" description={description}>
  <section class="legal-hero">
    <div class="wrap"><h1>{heading}</h1></div>
  </section>

  <div class="wrap legal">
    <!-- 语言胶囊下拉（先只做 EN；多语言接口保留在 /assets/api.js 的 Shedio.i18n） -->
    <div class="legal-langbar">
      <!-- 先只做 EN：静态胶囊（无原生下拉弹层，避免错位）；多语言接口保留在 /assets/api.js 的 Shedio.i18n -->
      <span class="lang-static" title="Language">🇺🇸 EN <span class="lang-caret" aria-hidden="true">▾</span></span>
    </div>

    <div class="legal-grid">
      <!-- 左侧：全部 policy 跳转导航（当前页高亮 / 占位灰显） -->
      <aside class="legal-nav" aria-label="Policies">
        <ul>
          {policies.map(p => {
            const active = !!p.href && p.href.replace(/\/+$/, '') === path;
            const cls = active ? 'is-active' : (p.href ? '' : 'is-placeholder');
            return (
              <li class={cls}>
                {p.href
                  ? <a href={p.href} aria-current={active ? 'page' : undefined}>{p.label}</a>
                  : (
                    <span>
                      {p.label}
                      {p.badge === 'choices' && <em class="pc-badge" aria-hidden="true">✓&nbsp;✕</em>}
                    </span>
                  )}
              </li>
            );
          })}
        </ul>
      </aside>

      <!-- 右侧：正文 -->
      <article class="legal-body">
        <slot />
        {cookieDeclaration && <CookieDeclaration />}
      </article>
    </div>
  </div>

  <style is:global>
    /* ---- Hero ---- */
    .legal-hero{background:var(--surface-tint);border-bottom:1px solid var(--line);padding:var(--section-y) 0}
    .legal-hero h1{text-align:center;font-size:var(--fs-h1);font-weight:var(--fw-bold);line-height:var(--lh-heading);color:var(--navy);letter-spacing:var(--ls-display)}

    /* ---- 语言下拉（多语言接口占位）---- */
    .legal{padding:0 0 90px}
    .legal-langbar{display:flex;justify-content:flex-end;padding:22px 0 6px}
    .lang-static{display:inline-flex;align-items:center;gap:var(--space-2);border:1px solid var(--line-strong);background:#fff;
      border-radius:var(--r-sm);padding:var(--space-2) var(--space-3);font-size:var(--fs-small);font-weight:var(--fw-semibold);color:var(--ink);line-height:1;white-space:nowrap}
    .lang-static .lang-caret{color:var(--muted);font-size:12px}

    /* ---- 两栏：侧栏导航 + 正文 ---- */
    .legal-grid{display:grid;grid-template-columns:280px 1fr;gap:var(--space-7);align-items:start}

    .legal-nav{position:sticky;top:92px}
    .legal-nav ul{list-style:none;margin:0;padding:0}
    .legal-nav li{margin:2px 0}
    .legal-nav a,.legal-nav span{
      display:block;padding:var(--space-3) var(--space-4);font-size:var(--fs-ui);line-height:1.35;color:var(--muted);
      border-left:3px solid transparent;border-radius:0 var(--r-sm) var(--r-sm) 0;transition:color var(--dur),background var(--dur);
    }
    .legal-nav a:hover{color:var(--ink);font-weight:var(--fw-semibold);background:transparent}
    .legal-nav li.is-active a{
      color:var(--navy);font-weight:var(--fw-bold);border-left-color:var(--coral);background:transparent;
    }
    .legal-nav li.is-placeholder span{color:#b9b3a6;cursor:default;display:flex;align-items:center;gap:8px}
    /* “Your Privacy Choices” 的小徽标（占位）*/
    .pc-badge{
      font-style:normal;font-size:10px;font-weight:700;color:#fff;background:#2f6bff;
      border-radius:999px;padding:3px 7px;letter-spacing:.5px;white-space:nowrap;
    }

    /* ---- 正文排版 ---- */
    .legal-body{font-size:var(--fs-body);line-height:var(--lh-loose);color:#2c2a26;min-width:0;max-width:var(--measure-wide)}
    .legal-body h2{font-size:var(--fs-h3);font-weight:var(--fw-bold);color:var(--navy);line-height:var(--lh-heading);margin:1.8em 0 .5em;letter-spacing:var(--ls-heading)}
    .legal-body h3{font-size:var(--fs-h5);font-weight:var(--fw-bold);color:var(--navy);margin:1.6em 0 .4em}
    .legal-body h4{font-size:var(--fs-ui);font-weight:var(--fw-bold);color:var(--ink);margin:1.4em 0 .4em}
    .legal-body p{margin:12px 0}
    .legal-body a{color:var(--coral);text-decoration:underline;text-underline-offset:2px;word-break:break-word}
    .legal-body a:hover{color:var(--coral-deep)}
    .legal-body ul,.legal-body ol{margin:12px 0 12px 22px;padding:0}
    .legal-body li{margin:6px 0}
    .legal-body strong{font-weight:var(--fw-bold);color:var(--ink)}
    .legal-body hr{border:0;border-top:1px solid var(--line);margin:var(--space-6) 0}
    .legal-body table{width:100%;border-collapse:collapse;margin:var(--space-4) 0;font-size:var(--fs-small);display:block;overflow-x:auto}
    .legal-body th,.legal-body td{
      border:0;padding:var(--space-4);text-align:left;vertical-align:top;
      box-shadow:inset -1px 0 var(--line),inset 0 -1px var(--line);
    }
    .legal-body table tr > :first-child:not(:only-child){
      box-shadow:inset 1px 0 var(--line),inset -1px 0 var(--line),inset 0 -1px var(--line);
    }
    .legal-body table > :first-child > tr:first-child > *:not(:only-child){
      box-shadow:inset -1px 0 var(--line),inset 0 1px var(--line),inset 0 -1px var(--line);
    }
    .legal-body table > :first-child > tr:first-child > :first-child:not(:only-child){
      box-shadow:inset 1px 0 var(--line),inset -1px 0 var(--line),inset 0 1px var(--line),inset 0 -1px var(--line);
    }
    .legal-body thead th{background:transparent;font-weight:var(--fw-bold);color:var(--navy)}
    /* Markdown 中用单列表格承载的法律提示，只保留正文，不显示卡片/表格外观。 */
    .legal-body table tr > :only-child{
      border:0;padding:0;background:transparent;box-shadow:none;
      color:inherit;font-size:var(--fs-body);font-weight:inherit;line-height:var(--lh-loose);
    }
    .legal-body h2:first-child,.legal-body h3:first-child{margin-top:0}

    /* ---- 响应式：窄屏堆叠，导航移到正文上方，可横向滚动 ---- */
    @media(max-width:860px){
      .legal-grid{grid-template-columns:1fr;gap:24px}
      .legal-nav{position:static;border:1px solid var(--line);border-radius:var(--r-sm);padding:var(--space-2);background:#fff}
      .legal-nav a,.legal-nav span{border-left:0;border-radius:8px;padding:11px 14px}
      .legal-nav li.is-active a{border-left:0;box-shadow:inset 3px 0 0 var(--coral)}
      /* 正文左右留出边距（对齐 blog，避免贴边） */
      .legal{padding-left:22px;padding-right:22px}
    }
    /* 手机端细化（≤600px） */
    @media(max-width:600px){
      .legal-hero{padding:40px 0}
      .legal{padding:0 18px 60px}
      .legal-body table{font-size:var(--fs-small)}
      .legal-langbar{padding:16px 0 4px}
    }
  </style>
</Base>
