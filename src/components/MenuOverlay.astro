---
// 全局组件 · Menu 抽屉（Nav ≡ 拉起；锁滚动 / 点外 / Esc 关闭 — 逻辑在 /assets/app.js）
---
<div class="overlay" id="menuOverlay">
  <div class="overlay-media ph" data-ph="menu.webp"><img src="/images/menu.webp" alt="" onload="this.parentNode.classList.add('has-img')" onerror="this.style.display='none'"></div>
  <div class="overlay-panel">
    <div class="overlay-top">
      <a href="/login/" class="btn btn-coral" style="display:none">Log in</a>
      <button class="overlay-close" data-close aria-label="Close">✕</button>
    </div>
    <nav class="overlay-nav">
      <a href="/about/">About Us</a>
      <a href="/blog/">Blog</a>
      <a href="/help">Help Center</a>
    </nav>
    <div class="overlay-foot">
      <div class="overlay-legal">
        <a href="/terms">Terms of Use</a>
        <a href="/subscription-terms">Subscription terms</a>
        <a href="/privacy">Privacy policy</a>
        <a href="/money-back-policy">Money-back policy</a>
        <a href="#" data-cookie-settings>e-Privacy Settings</a>
      </div>
      <div class="overlay-lang">EN</div>
    </div>
  </div>
</div>
