---
// 全局组件 · 厚 Footer（社交 + 导航列 + 合规信息 + 底部法律行 + Contact 锚点）
interface Props { brand?: string; }
const { brand = 'Shedio' } = Astro.props;
---
<footer class="site-footer" id="contact">
  <div class="wrap">
    <div class="footer-top">
      <div class="footer-brand">
        <!-- 社交：先隐藏。启用时去掉 style="display:none"，并把各 href="#" 换成真实主页 URL -->
        <div class="footer-social" style="display:none">
          <a href="#" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="3.6"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="#" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.5 3c.35 2.06 1.62 3.53 3.6 3.86v2.7c-1.3.06-2.53-.3-3.6-1.03v5.94a5.55 5.55 0 1 1-5.55-5.55c.28 0 .55.02.82.06v2.83a2.72 2.72 0 1 0 1.9 2.6V3h2.83z"/></svg>
          </a>
          <a href="#" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-8h2.6l.4-3h-3V8.1c0-.86.26-1.45 1.5-1.45H17V4a20 20 0 0 0-2.2-.11c-2.2 0-3.7 1.34-3.7 3.8V10H8.5v3h2.6v8h2.4z"/></svg>
          </a>
          <a href="#" aria-label="X">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.9 2.5H22l-7.02 8.02L23 21.5h-6.36l-4.98-6.51-5.7 6.51H2.85l7.5-8.58L2 2.5h6.53l4.5 5.95 5.87-5.95zm-1.12 17.1h1.72L7.3 4.3H5.46l12.32 15.3z"/></svg>
          </a>
          <a href="#" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.9 8.5v11H3.5v-11h3.4zM5.2 3.2a2 2 0 1 1 0 4 2 2 0 0 1 0-4zM20.5 19.5h-3.4v-5.9c0-1.48-.6-2.36-1.8-2.36-.98 0-1.5.66-1.76 1.3-.1.23-.08.55-.08.87v6.09H9.6s.05-9.88 0-10.9h3.4v1.54c.45-.7 1.26-1.7 3.1-1.7 2.26 0 3.96 1.48 3.96 4.66v6.4z"/></svg>
          </a>
        </div>

        <p class="footer-copy">© 2026 {brand}</p>
        <p class="footer-disclaimer">Our website provides information and products only for general wellness and healthy lifestyle. It is not a medical product, drug, device, or treatment.</p>
      </div>

      <nav class="footer-cols" aria-label="Footer">
        <div class="footer-col">
          <h4>Explore</h4>
          <a href="/#features">App Features</a>
          <a href="/about/">About Us</a>
          <a href="/blog/">Blog</a>
        </div>
        <div class="footer-col">
          <h4>Contact</h4>
          <a href="mailto:support@shedio.life">support@shedio.life</a>
          <a href="/help">Help Center</a>
        </div>
      </nav>
    </div>

    <div class="footer-legal">
      <a href="/help">Need Help?</a>
      <a href="/terms">Terms of Use</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="/cookie-policy">Cookie Policy</a>
      <a href="/subscription-terms">Subscription Terms</a>
      <a href="/money-back-policy">Money-back Policy</a>
      <a href="/consumer-health-data">Consumer Health Data Privacy Policy</a>
      <!-- Cookiebot：点击重新打开 Cookie 同意弹窗（未配置/未加载时静默，不报错） -->
      <a href="#" data-cookie-settings>e-Privacy Settings</a>
    </div>
  </div>
</footer>
